#!/bin/bash
set -e

# $1 = "configure" (always for postinst)

ensure_directory_owner() {
    local dir="$1"
    local create="$2"
    if [ "$create" = "true" ]; then
        mkdir -p "$dir"
    fi
    chown ubse:ubse "$dir"
}

